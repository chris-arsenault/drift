#!/usr/bin/env bash
# drift — wrapper CLI for drift-semantic.
#
# Proxies all pipeline commands to cli.sh and adds management commands:
#   drift version          Show version and install path
#   drift upgrade          Pull latest and refresh dependencies
#   drift self-update      Alias for upgrade
#   drift install-skill    Install Claude Code skills to a project
#   drift library          Manage the centralized drift artifact library
#   drift online           Enable auto-push/pull (library ops run transparently)
#   drift offline          Disable auto-push/pull (manual library push/pull)
#   drift ui               Launch the drift dashboard
#
# All other commands pass through to cli.sh unchanged.

set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve install directory
# ---------------------------------------------------------------------------

DRIFT_HOME="${DRIFT_SEMANTIC:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

if [[ ! -f "$DRIFT_HOME/cli.sh" ]]; then
    echo "ERROR: drift-semantic installation not found at $DRIFT_HOME" >&2
    echo "Install: curl -fsSL https://raw.githubusercontent.com/chris-arsenault/drift/main/install.sh | bash" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------

if [[ -t 2 ]]; then
    _R='\033[0m' _G='\033[0;32m' _Y='\033[0;33m' _B='\033[0;34m' _RED='\033[0;31m'
else
    _R='' _G='' _Y='' _B='' _RED=''
fi

info()    { printf "${_B}[*]${_R} %s\n" "$*" >&2; }
success() { printf "${_G}[+]${_R} %s\n" "$*" >&2; }
warn()    { printf "${_Y}[!]${_R} %s\n" "$*" >&2; }
error()   { printf "${_RED}[-]${_R} %s\n" "$*" >&2; }

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

drift_version() {
    local sha date ver
    sha="$(git -C "$DRIFT_HOME" rev-parse --short HEAD 2>/dev/null || echo "unknown")"
    date="$(git -C "$DRIFT_HOME" log -1 --format=%cd --date=short 2>/dev/null || echo "unknown")"
    ver="$(sed -n 's/^version *= *"\(.*\)"/\1/p' "$DRIFT_HOME/pipeline/pyproject.toml" 2>/dev/null || echo "0.0.0")"
    echo "drift-semantic $ver ($sha $date)"
    echo "Install: $DRIFT_HOME"
}

drift_upgrade() {
    info "Upgrading drift-semantic..."

    if [[ ! -d "$DRIFT_HOME/.git" ]]; then
        error "Not a git repository: $DRIFT_HOME"
        error "Cannot upgrade a non-git installation."
        exit 1
    fi

    # Save dependency file checksums before pull
    local old_pkg old_pyproject
    old_pkg="$(cksum "$DRIFT_HOME/extractor/package.json" 2>/dev/null || echo "")"
    old_pyproject="$(cksum "$DRIFT_HOME/pipeline/pyproject.toml" 2>/dev/null || echo "")"

    # Pull latest
    if ! git -C "$DRIFT_HOME" pull --ff-only 2>&1; then
        error "git pull failed. You may have local modifications."
        error "Run: cd $DRIFT_HOME && git status"
        exit 1
    fi

    # Compare checksums — only clear deps if they changed
    local new_pkg new_pyproject
    new_pkg="$(cksum "$DRIFT_HOME/extractor/package.json" 2>/dev/null || echo "")"
    new_pyproject="$(cksum "$DRIFT_HOME/pipeline/pyproject.toml" 2>/dev/null || echo "")"

    if [[ "$old_pkg" != "$new_pkg" ]] && [[ -d "$DRIFT_HOME/extractor/node_modules" ]]; then
        warn "package.json changed — clearing node_modules"
        rm -rf "$DRIFT_HOME/extractor/node_modules"
    fi

    if [[ "$old_pyproject" != "$new_pyproject" ]] && [[ -d "$DRIFT_HOME/pipeline/.venv" ]]; then
        warn "pyproject.toml changed — clearing venv"
        rm -rf "$DRIFT_HOME/pipeline/.venv"
    fi

    success "Upgrade complete."
}

drift_install_skill() {
    local target_dir="${1:-.}"

    if [[ ! -d "$target_dir" ]]; then
        error "Directory does not exist: $target_dir"
        exit 1
    fi

    target_dir="$(cd "$target_dir" && pwd)"

    # -- Install all skill definitions -------------------------------------

    local skill_base="$DRIFT_HOME/skill"
    local dest_base="$target_dir/.claude/skills"
    local skills=(drift drift-audit drift-audit-ux drift-audit-semantic drift-unify drift-guard)

    for skill_name in "${skills[@]}"; do
        local src="$skill_base/$skill_name/SKILL.md"
        if [[ ! -f "$src" ]]; then
            warn "Skill not found: $skill_name (skipping)"
            continue
        fi
        local dest="$dest_base/$skill_name"
        mkdir -p "$dest"
        cp "$src" "$dest/SKILL.md"
        success "Installed: .claude/skills/$skill_name/SKILL.md"
    done

    # Copy drift-guard references
    if [[ -d "$skill_base/drift-guard/references" ]]; then
        mkdir -p "$dest_base/drift-guard/references"
        cp "$skill_base/drift-guard/references/"*.md "$dest_base/drift-guard/references/"
        success "Installed: .claude/skills/drift-guard/references/"
    fi

    # -- Create default project config (before CLAUDE.md so we can read mode) --

    local config_file="$target_dir/.drift-audit/config.json"
    local mode="offline"
    if [[ ! -f "$config_file" ]]; then
        mkdir -p "$target_dir/.drift-audit"
        cat > "$config_file" << 'CFGEOF'
{
  "library": "~/.drift/library",
  "mode": "offline",
  "sync": {
    "eslint-rule": "eslint-rules/",
    "adr": "docs/adr/",
    "pattern": "docs/patterns/",
    "checklist": "docs/"
  }
}
CFGEOF
        success "Created .drift-audit/config.json"
    else
        # Read existing mode preference
        mode="$(_read_config_mode "$config_file")"
        info ".drift-audit/config.json already exists — skipping."
    fi

    # -- Update CLAUDE.md --------------------------------------------------

    _refresh_claude_block "$target_dir" "$mode"

    # -- Register project in dashboard registry ----------------------------

    _register_project "$target_dir"

    # -- Suggest .gitignore entry ------------------------------------------

    local gitignore="$target_dir/.gitignore"
    if [[ -f "$gitignore" ]]; then
        if ! grep -q '\.drift-audit' "$gitignore" 2>/dev/null; then
            echo ""
            warn "Consider adding '.drift-audit/' to your .gitignore"
        fi
    fi
}

_refresh_claude_block() {
    local target_dir="$1"
    local mode="${2:-offline}"
    local claude_md="$target_dir/.claude/CLAUDE.md"
    mkdir -p "$target_dir/.claude"

    if [[ -f "$claude_md" ]]; then
        if grep -q "<!-- drift-semantic -->" "$claude_md" 2>/dev/null; then
            sed -i '/<!-- drift-semantic -->/,/<!-- \/drift-semantic -->/d' "$claude_md"
            _append_claude_block "$claude_md" "$mode"
            success "Updated drift block in CLAUDE.md (mode: $mode)"
        elif grep -q "DRIFT_SEMANTIC" "$claude_md" 2>/dev/null; then
            info "CLAUDE.md already references DRIFT_SEMANTIC — skipping."
        else
            _append_claude_block "$claude_md" "$mode"
            success "Appended drift config to CLAUDE.md (mode: $mode)"
        fi
    else
        _append_claude_block "$claude_md" "$mode"
        success "Created .claude/CLAUDE.md (mode: $mode)"
    fi
}

_append_claude_block() {
    local file="$1"
    local mode="${2:-offline}"

    # Common header
    cat >> "$file" << 'BLOCK'

<!-- drift-semantic -->
## Drift

`drift` is installed at `~/.drift-semantic` (`$DRIFT_SEMANTIC`).

Run the full drift pipeline:
```bash
drift run --project .    # semantic analysis pipeline
```

Drift skills (installed in `.claude/skills/`):
- `drift` — orchestrator: audit → plan → unify → guard
- `drift-audit` — structural drift discovery
- `drift-audit-ux` — behavioral drift discovery
- `drift-audit-semantic` — semantic duplication detection (tool-assisted)
- `drift-unify` — batch refactoring toward canonical patterns
- `drift-guard` — generate ESLint rules, ADRs, pattern docs
BLOCK

    # Mode-specific library section
    if [[ "$mode" == "online" ]]; then
        cat >> "$file" << 'BLOCK'

Centralized artifact library (online mode — auto-push/pull enabled):
```bash
drift library init       # initialize ~/.drift/library
drift library list       # show library contents
drift library status     # compare library vs project
```

**Auto-push/pull behavior:** Library operations are automatic. Before starting
any drift audit phase, run `drift library pull` to pull the latest artifacts
from the centralized library. After completing any drift-guard phase, run
`drift library push` to share new artifacts back to the library.
Do not ask for confirmation — run silently as part of the pipeline.
<!-- /drift-semantic -->
BLOCK
    else
        cat >> "$file" << 'BLOCK'

Centralized artifact library:
```bash
drift library init       # initialize ~/.drift/library
drift library push    # push guard artifacts to library
drift library pull       # pull matching artifacts into project
drift library list       # show library contents
drift library status     # compare library vs project
```
<!-- /drift-semantic -->
BLOCK
    fi
}

drift_online() {
    _require_python3
    local config_file
    config_file="$(_find_project_config)"
    local project_root
    project_root="$(dirname "$(dirname "$config_file")")"

    _set_config_mode "$config_file" "online"
    _refresh_claude_block "$project_root" "online"
    success "Online mode enabled — library push/pull is now automatic."
}

drift_offline() {
    _require_python3
    local config_file
    config_file="$(_find_project_config)"
    local project_root
    project_root="$(dirname "$(dirname "$config_file")")"

    _set_config_mode "$config_file" "offline"
    _refresh_claude_block "$project_root" "offline"
    success "Offline mode enabled — run 'drift library pull' and 'drift library push' manually."
}

drift_ui() {
    local dash_dir="$DRIFT_HOME/dashboard"

    if [[ ! -f "$dash_dir/package.json" ]]; then
        error "Dashboard not found at $dash_dir"
        exit 1
    fi

    # Ensure dependencies are installed
    if [[ ! -d "$dash_dir/node_modules" ]]; then
        info "Installing dashboard dependencies..."
        (cd "$dash_dir" && npm install --no-fund --no-audit) || {
            error "npm install failed"
            exit 1
        }
    fi

    info "Starting drift dashboard at http://localhost:47018"
    cd "$dash_dir" && exec npm run dev
}

drift_library() {
    local subcmd="${1:-help}"
    shift || true

    case "$subcmd" in
        init)
            drift_library_init "$@"
            ;;
        push|publish)
            drift_library_push "$@"
            ;;
        pull|sync)
            drift_library_pull "$@"
            ;;
        list|ls)
            drift_library_list "$@"
            ;;
        status)
            drift_library_status "$@"
            ;;
        commit)
            drift_library_commit "$@"
            ;;
        remote)
            drift_library_remote "$@"
            ;;
        remote-push)
            drift_library_remote_push "$@"
            ;;
        remote-pull)
            drift_library_remote_pull "$@"
            ;;
        help|--help|-h)
            cat >&2 <<'USAGE'
Usage: drift library <command>

Commands:
  init [path]        Initialize the drift artifact library (default: ~/.drift/library)
  push               Push guard artifacts from current project to library
  pull               Pull artifacts from library into current project
  list               Show all artifacts in the library
  status             Compare library artifacts vs current project
  commit             Stage all changes and commit to local git
  remote [url]       Show or set the remote origin URL
  remote-push        Push committed changes to remote
  remote-pull        Pull latest changes from remote
USAGE
            ;;
        *)
            error "Unknown library command: $subcmd"
            error "Run 'drift library help' for usage."
            exit 1
            ;;
    esac
}

drift_library_init() {
    local lib_path="${1:-$HOME/.drift/library}"

    if [[ -d "$lib_path" ]] && [[ -f "$lib_path/library.json" ]]; then
        info "Library already exists at $lib_path"
    else
        mkdir -p "$lib_path"/{rules/eslint,rules/ruff,rules/ast-grep,adr,patterns,checklists}

        cat > "$lib_path/library.json" << 'INITEOF'
{
  "version": 1,
  "artifacts": []
}
INITEOF

        success "Initialized drift library at $lib_path"
        info "Add artifacts with: drift library push (from a project)"
    fi

    # Git init (idempotent)
    if [[ ! -d "$lib_path/.git" ]]; then
        git -C "$lib_path" init -b main >/dev/null 2>&1
        success "Initialized git repository in library"
    fi
}

drift_library_push() {
    _require_python3
    local config_file
    config_file="$(_find_project_config)"
    exec "$_DRIFT_PY" "$DRIFT_HOME/scripts/library-push.py" "$config_file"
}

drift_library_pull() {
    _require_python3
    local config_file
    config_file="$(_find_project_config)"
    exec "$_DRIFT_PY" "$DRIFT_HOME/scripts/library-pull.py" "$config_file"
}

drift_library_list() {
    _require_python3
    local config_file lib_path

    # Try project config first, fall back to default library path
    config_file="$(_find_project_config 2>/dev/null || echo "")"
    if [[ -n "$config_file" ]]; then
        exec "$_DRIFT_PY" "$DRIFT_HOME/scripts/library-status.py" --list "$config_file"
    else
        lib_path="${1:-$HOME/.drift/library}"
        if [[ ! -f "$lib_path/library.json" ]]; then
            error "No library found at $lib_path"
            error "Run 'drift library init' first."
            exit 1
        fi
        exec "$_DRIFT_PY" "$DRIFT_HOME/scripts/library-status.py" --list --library "$lib_path"
    fi
}

drift_library_status() {
    _require_python3
    local config_file
    config_file="$(_find_project_config)"
    exec "$_DRIFT_PY" "$DRIFT_HOME/scripts/library-status.py" "$config_file"
}

drift_library_commit() {
    local lib_path="${1:-$HOME/.drift/library}"

    if [[ ! -d "$lib_path/.git" ]]; then
        error "Library is not a git repository."
        error "Run 'drift library init' first."
        exit 1
    fi

    git -C "$lib_path" add -A

    if git -C "$lib_path" diff --cached --quiet; then
        info "Nothing to commit — library is clean."
        return 0
    fi

    local changed
    changed="$(git -C "$lib_path" diff --cached --name-only | wc -l | tr -d ' ')"
    local msg="Update library: ${changed} file(s) modified"

    git -C "$lib_path" commit -m "$msg" >/dev/null
    success "Committed: $msg"
}

drift_library_remote() {
    local lib_path="$HOME/.drift/library"

    if [[ ! -d "$lib_path/.git" ]]; then
        error "Library is not a git repository."
        error "Run 'drift library init' first."
        exit 1
    fi

    local url="${1:-}"

    if [[ -z "$url" ]]; then
        local current
        current="$(git -C "$lib_path" remote get-url origin 2>/dev/null || echo "")"
        if [[ -n "$current" ]]; then
            echo "origin: $current"
        else
            info "No remote configured."
            info "Set one with: drift library remote <url>"
        fi
    else
        if git -C "$lib_path" remote get-url origin &>/dev/null; then
            git -C "$lib_path" remote set-url origin "$url"
        else
            git -C "$lib_path" remote add origin "$url"
        fi
        success "Remote origin set to: $url"
    fi
}

drift_library_remote_push() {
    local lib_path="$HOME/.drift/library"

    if [[ ! -d "$lib_path/.git" ]]; then
        error "Library is not a git repository."
        exit 1
    fi

    if ! git -C "$lib_path" remote get-url origin &>/dev/null; then
        error "No remote configured."
        error "Set one with: drift library remote <url>"
        exit 1
    fi

    info "Pushing to remote..."
    local branch
    branch="$(git -C "$lib_path" branch --show-current)"
    if git -C "$lib_path" push -u origin "$branch" 2>&1; then
        success "Pushed to remote."
    else
        error "Push failed. Check remote access and try again."
        exit 1
    fi
}

drift_library_remote_pull() {
    local lib_path="$HOME/.drift/library"

    if [[ ! -d "$lib_path/.git" ]]; then
        error "Library is not a git repository."
        exit 1
    fi

    if ! git -C "$lib_path" remote get-url origin &>/dev/null; then
        error "No remote configured."
        error "Set one with: drift library remote <url>"
        exit 1
    fi

    info "Pulling from remote..."
    if git -C "$lib_path" pull --ff-only 2>&1; then
        success "Pulled from remote."
    else
        error "Pull failed. You may have local changes that conflict."
        error "Run 'drift library commit' first, then retry."
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Python discovery (shared with cli.sh)
# ---------------------------------------------------------------------------

# Source the discovery function from cli.sh so both entry points use the same
# logic. cli.sh defines discover_python() which sets $PYTHON3.
_drift_discover_python() {
    if [[ -n "${_DRIFT_PY:-}" ]]; then
        return 0
    fi
    # We only need a python3 for JSON manipulation — the full venv setup
    # isn't needed. Try a simpler discovery chain.
    local py

    # 1. System python3
    if command -v python3 &>/dev/null; then
        py="python3"
    # 2. uv-managed
    elif command -v uv &>/dev/null; then
        py="$(uv python find '>=3.10' 2>/dev/null)" || true
    # 3. Versioned binaries
    else
        local ver
        for ver in 14 13 12 11 10; do
            if command -v "python3.$ver" &>/dev/null; then
                py="python3.$ver"
                break
            fi
        done
    fi

    # 4. pyenv
    if [[ -z "${py:-}" ]] && command -v pyenv &>/dev/null; then
        local pyenv_root
        pyenv_root="$(pyenv root 2>/dev/null)"
        for ver_dir in "$pyenv_root"/versions/3.*/bin/python3; do
            if [[ -x "$ver_dir" ]]; then
                py="$ver_dir"
                break
            fi
        done
    fi

    # 5. mise/asdf shims
    if [[ -z "${py:-}" ]]; then
        for shimdir in "$HOME/.local/share/mise/shims" "$HOME/.asdf/shims"; do
            if [[ -x "$shimdir/python3" ]]; then
                py="$shimdir/python3"
                break
            fi
        done
    fi

    if [[ -z "${py:-}" ]]; then
        error "python3 is required but was not found."
        error "Install via: uv python install 3.12, apt install python3, or brew install python@3.12"
        exit 1
    fi

    _DRIFT_PY="$py"
}

# ---------------------------------------------------------------------------
# Library helpers
# ---------------------------------------------------------------------------

_read_config_mode() {
    _drift_discover_python
    "$_DRIFT_PY" -c "
import json, sys
with open(sys.argv[1]) as f:
    print(json.load(f).get('mode', 'offline'))
" "$1" 2>/dev/null || echo "offline"
}

_set_config_mode() {
    _drift_discover_python
    "$_DRIFT_PY" -c "
import json, sys
path, mode = sys.argv[1], sys.argv[2]
with open(path) as f:
    cfg = json.load(f)
cfg['mode'] = mode
with open(path, 'w') as f:
    json.dump(cfg, f, indent=2)
    f.write('\n')
" "$1" "$2"
}

_require_python3() {
    _drift_discover_python
}

_register_project() {
    _drift_discover_python
    local project_path="$1"
    local registry_path="$HOME/.drift/registry.json"

    "$_DRIFT_PY" -c "
import json, os, sys
from datetime import datetime, timezone

project_path = sys.argv[1]
registry_path = sys.argv[2]
name = os.path.basename(project_path)

os.makedirs(os.path.dirname(registry_path), exist_ok=True)

registry = {'version': 1, 'projects': []}
if os.path.isfile(registry_path):
    try:
        with open(registry_path) as f:
            registry = json.load(f)
    except (json.JSONDecodeError, OSError):
        pass

# Skip if already registered
if any(p.get('path') == project_path for p in registry.get('projects', [])):
    sys.exit(0)

registry.setdefault('projects', []).append({
    'path': project_path,
    'name': name,
    'added': datetime.now(timezone.utc).isoformat(),
    'lastRun': None
})

with open(registry_path, 'w') as f:
    json.dump(registry, f, indent=2)
    f.write('\n')
" "$project_path" "$registry_path" 2>/dev/null && \
        success "Registered project in drift dashboard" || true
}

_find_project_config() {
    # Walk up from cwd looking for .drift-audit/config.json
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.drift-audit/config.json" ]]; then
            echo "$dir/.drift-audit/config.json"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    error "No .drift-audit/config.json found (searched from $PWD to /)."
    error "Run 'drift install-skill' in your project first."
    exit 1
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    version|--version|-v|-V)
        drift_version
        ;;
    upgrade|self-update)
        drift_upgrade
        ;;
    install-skill)
        drift_install_skill "$@"
        ;;
    library)
        drift_library "$@"
        ;;
    online)
        drift_online "$@"
        ;;
    offline)
        drift_offline "$@"
        ;;
    ui|dashboard)
        drift_ui "$@"
        ;;
    *)
        exec bash "$DRIFT_HOME/cli.sh" "$COMMAND" "$@"
        ;;
esac
